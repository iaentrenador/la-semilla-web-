---
import { getCollection } from 'astro:content';

// 1. Generar las rutas para cada tomo en la carpeta content/tomos
export async function getStaticPaths() {
  const tomosEntries = await getCollection('tomos');
  return tomosEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

// 2. Agarrar el contenido del tomo específico
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{entry.data.title} | La Semilla de la Resistencia</title>
</head>
<body style="background-color: #fcfaf2; color: #1c2816; font-family: sans-serif; padding: 2rem; max-width: 800px; margin: 0 auto;">
    
    <a href="/" style="color: #436132; text-decoration: none; font-weight: bold;">← Volver al Inicio</a>
    
    <header style="margin-top: 2rem; border-bottom: 2px dashed #436132; padding-bottom: 1rem;">
        <span style="background: #436132; color: white; padding: 0.2rem 0.6rem; font-size: 0.8rem; font-weight: bold; borderRadius: 4px;">
            VOLUMEN {entry.data.volumen}
        </span>
        <h1 style="font-size: 2.5rem; margin: 0.5rem 0; color: #23361b;">{entry.data.title}</h1>
        <p style="color: #666; font-style: italic;">Publicado el: {entry.data.fecha}</p>
        <p style="font-size: 1.1rem; line-height: 1.6; color: #3c4d35;">{entry.data.descripcion}</p>
    </header>

    <main style="line-height: 1.8; font-size: 1.1rem; margin-top: 2rem;">
        <Content />
    </main>

</body>
</html>

